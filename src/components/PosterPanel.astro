---
import type { Edition } from '../data/site';

interface Props {
	edition: Edition;
	size?: 'mini' | 'card' | 'hero';
}

const { edition, size = 'card' } = Astro.props;
---

<div
	class={`poster-panel poster-${size}`}
	style={`--poster-start: ${edition.palette.start}; --poster-end: ${edition.palette.end}; --poster-accent: ${edition.palette.accent};`}
	transition:name={`edition-poster-${edition.slug}`}
>
	<div class="poster-top">
		<span class="poster-badge">Edition {String(edition.index).padStart(2, '0')}</span>
		<span class="poster-duration">{edition.duration}</span>
	</div>

	<div class="poster-copy">
		<p class="poster-label">{edition.path}</p>
		<h3>{edition.title}</h3>
		<p>{edition.strapline}</p>
	</div>
</div>

<style>
	.poster-panel {
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 280px;
		padding: 22px;
		border-radius: 28px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.14), transparent 26%),
			linear-gradient(145deg, var(--poster-start), var(--poster-end));
		isolation: isolate;
		transition:
			transform var(--dur-mid) var(--ease-soft),
			border-color var(--dur-fast) ease;
	}

	.poster-panel::before {
		content: '';
		position: absolute;
		inset: auto -8% -24% 44%;
		aspect-ratio: 1;
		border-radius: 999px;
		background: radial-gradient(circle, color-mix(in srgb, var(--poster-accent) 30%, transparent), transparent 70%);
		opacity: 0.9;
		filter: blur(12px);
		z-index: -1;
	}

	.poster-panel::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(120deg, rgba(255, 255, 255, 0.08), transparent 36%),
			repeating-linear-gradient(
				90deg,
				rgba(255, 255, 255, 0.03) 0,
				rgba(255, 255, 255, 0.03) 1px,
				transparent 1px,
				transparent 84px
			);
		opacity: 0.35;
	}

	.poster-panel:hover {
		transform: translateY(-2px);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.poster-top,
	.poster-copy {
		position: relative;
		z-index: 1;
	}

	.poster-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.poster-badge,
	.poster-duration,
	.poster-label {
		font-family: 'IBM Plex Mono', 'Cascadia Code', monospace;
		font-size: 0.72rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.poster-badge {
		display: inline-flex;
		width: fit-content;
		padding: 7px 10px;
		border-radius: 999px;
		background: rgba(17, 20, 24, 0.28);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: rgba(255, 248, 241, 0.82);
	}

	.poster-duration {
		color: rgba(255, 248, 241, 0.72);
	}

	.poster-copy {
		max-width: min(90%, 420px);
	}

	.poster-label {
		margin: 0 0 12px;
		color: rgba(255, 248, 241, 0.72);
	}

	.poster-copy h3 {
		margin: 0;
		font-size: clamp(1.6rem, 2.8vw, 2.55rem);
		line-height: 0.96;
		letter-spacing: -0.055em;
	}

	.poster-copy p:last-child {
		margin: 12px 0 0;
		color: rgba(255, 248, 241, 0.82);
		max-width: 34ch;
	}

	.poster-mini {
		min-height: 220px;
		aspect-ratio: 1 / 1.08;
	}

	.poster-card {
		aspect-ratio: 1 / 1.18;
	}

	.poster-hero {
		min-height: 420px;
		padding: 28px;
		aspect-ratio: 5 / 4;
	}

	@media (max-width: 720px) {
		.poster-panel {
			border-radius: 24px;
		}

		.poster-hero {
			min-height: 320px;
			aspect-ratio: 4 / 4.2;
		}
	}
</style>
