<style>
	:root {
		color-scheme: light;
		--ink: #141414;
		--soft-ink: rgba(20, 20, 20, 0.76);
		--line: rgba(20, 20, 20, 0.72);
		--panel: rgba(255, 255, 255, 0.2);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		overflow: hidden;
		background: #f3efe8;
	}

	body {
		font-family: "Georgia", "Times New Roman", serif;
		color: var(--ink);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.hero {
		position: relative;
		height: 100vh;
		height: 100svh;
		display: grid;
		place-items: center;
		padding: clamp(1.5rem, 3vw, 3rem);
		isolation: isolate;
	}

	.backdrop {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(rgba(251, 248, 243, 0.72), rgba(251, 248, 243, 0.72)),
			url("/bg3.webp") center center / cover no-repeat;
		filter: saturate(0.9) contrast(0.95);
		overflow: hidden;
		z-index: -2;
	}

	.backdrop::before {
		content: "";
		position: absolute;
		inset: -8%;
		background: url("/grain.webp") center center / 320px repeat;
		opacity: 0.24;
		mix-blend-mode: multiply;
		filter: contrast(1.0) brightness(0.95);
		pointer-events: none;
		z-index: 0;
	}

	.backdrop::after {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.44), transparent 52%),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.3));
		pointer-events: none;
		z-index: 1;
	}

	.content {
		width: min(920px, 100%);
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1rem;
		padding: clamp(1.5rem, 3vw, 2.5rem);
	}

	.eyebrow {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--soft-ink);
	}

	h1 {
		margin: 0;
		max-width: 12ch;
		font-size: clamp(2.7rem, 7.2vw, 6.6rem);
		line-height: 1;
		font-weight: 500;
		letter-spacing: -0.055em;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.08em;
	}

	.headline-rotator {
		position: relative;
		display: inline-flex;
		align-items: flex-start;
		justify-content: center;
		min-width: 11ch;
		height: 1.22em;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(0, 0, 0, 0.18) 4%,
			#000 16%,
			#000 84%,
			rgba(0, 0, 0, 0.18) 96%,
			transparent 100%
		);
		mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(0, 0, 0, 0.18) 4%,
			#000 16%,
			#000 84%,
			rgba(0, 0, 0, 0.18) 96%,
			transparent 100%
		);
	}

	.headline-track {
		display: flex;
		flex-direction: column;
		align-items: center;
		animation: headline-cycle 4.8s cubic-bezier(0.72, 0, 0.28, 1) infinite;
		will-change: transform;
	}

	.headline-static {
		display: block;
		color: rgba(20, 20, 20, 0.84);
	}

	.headline-word {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 1.22em;
		padding-bottom: 0.12em;
		text-shadow: none;
	}

	.meta {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-size: clamp(0.95rem, 1.4vw, 1.15rem);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--soft-ink);
	}

	.cta {
		margin-top: 0.35rem;
		padding: 0.95rem 1.7rem;
		border: 1px solid var(--line);
		background: var(--panel);
		font-family: Arial, Helvetica, sans-serif;
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		backdrop-filter: blur(8px);
	}

	.email {
		margin-top: clamp(1.2rem, 6vh, 4.5rem);
		font-size: clamp(1rem, 2vw, 1.22rem);
		letter-spacing: 0.02em;
	}

	.email-shell {
		display: inline-flex;
		align-items: center;
		padding: 0.72rem 1rem;
		border: 1px solid rgba(20, 20, 20, 0.16);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.28);
		box-shadow:
			0 10px 30px rgba(20, 20, 20, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.55);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		font-family: "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", Menlo, monospace;
	}

	.email-text {
		position: relative;
		color: rgba(20, 20, 20, 0.9);
		white-space: nowrap;
	}

	.email-text::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -0.14rem;
		height: 1px;
		background: linear-gradient(90deg, rgba(20, 20, 20, 0), rgba(20, 20, 20, 0.42), rgba(20, 20, 20, 0));
		transform-origin: center;
		animation: email-glow 3.4s ease-in-out infinite;
	}

	.socials {
		display: flex;
		gap: 1rem;
		align-items: center;
		justify-content: center;
	}

	.socials a {
		width: 3.25rem;
		height: 3.25rem;
		display: grid;
		place-items: center;
		border: 1px solid rgba(20, 20, 20, 0.24);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.22);
		backdrop-filter: blur(8px);
	}

	.socials svg {
		width: 1.55rem;
		height: 1.55rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.7;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.socials .fill {
		fill: currentColor;
		stroke: none;
	}

	@media (max-width: 720px) {
		.content {
			gap: 0.9rem;
		}

		h1 {
			max-width: 9.6ch;
			font-size: clamp(2.35rem, 12vw, 4.3rem);
		}

		.headline-rotator {
			min-width: 8.8ch;
		}

		.meta {
			font-size: 0.82rem;
			letter-spacing: 0.12em;
		}

		.cta {
			padding: 0.85rem 1.35rem;
			font-size: 0.82rem;
		}

		.email {
			margin-top: clamp(0.9rem, 4vh, 2.5rem);
			font-size: 0.96rem;
		}

		.email-shell {
			padding: 0.68rem 0.9rem;
			gap: 0.22rem;
		}

		.socials a {
			width: 3rem;
			height: 3rem;
		}
	}

	@media (max-height: 700px) {
		.content {
			gap: 0.75rem;
		}

		h1 {
			font-size: clamp(2.2rem, 8.5vh, 4.8rem);
		}

		.email {
			margin-top: 1rem;
		}
	}

	@keyframes headline-cycle {
		0% {
			transform: translateY(0);
		}

		33.333% {
			transform: translateY(-1.22em);
		}

		66.666% {
			transform: translateY(-2.44em);
		}

		100% {
			transform: translateY(-3.66em);
		}
	}

	@keyframes email-glow {
		0%,
		100% {
			opacity: 0.35;
			transform: scaleX(0.82);
		}

		50% {
			opacity: 0.8;
			transform: scaleX(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.headline-rotator {
			min-width: auto;
			height: auto;
			overflow: visible;
		}

		.headline-track {
			animation: none;
		}

		.headline-word {
			display: none;
			animation: none;
			transform: none;
			text-shadow: none;
		}

		.headline-word:first-child {
			display: flex;
		}

		.email-text::after {
			animation: none;
		}
	}
</style>
