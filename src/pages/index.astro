<style>
	:root {
		color-scheme: light;
		--bg: #fbf8f3;
		--ink: #141414;
		--soft-ink: rgba(20, 20, 20, 0.76);
		--line: rgba(20, 20, 20, 0.72);
		--panel: rgba(255, 255, 255, 0.22);

		--safe-top: env(safe-area-inset-top, 0px);
		--safe-right: env(safe-area-inset-right, 0px);
		--safe-bottom: env(safe-area-inset-bottom, 0px);
		--safe-left: env(safe-area-inset-left, 0px);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		height: 100%;
		margin: 0;
		background-color: var(--bg);
		-webkit-text-size-adjust: 100%;
	}

	body {
		margin: 0;
		min-height: 100%;
		min-height: 100svh;
		min-height: 100dvh;
		position: relative;
		overflow-x: hidden;
		background-color: var(--bg);
		font-family: Georgia, "Times New Roman", serif;
		color: var(--ink);
		isolation: isolate;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	/* Fixed background layer */
	body::before {
		content: "";
		position: fixed;
		inset: 0;
		background:
			linear-gradient(rgba(251, 248, 243, 0.72), rgba(251, 248, 243, 0.72)),
			url("/bg3.webp") center center / cover no-repeat;
		pointer-events: none;
		z-index: -3;
		transform: translateZ(0);
	}

	/* Grain */
	body::after {
		content: "";
		position: fixed;
		inset: -10%;
		background: url("/grain.webp") center center / 320px repeat;
		opacity: 0.22;
		mix-blend-mode: multiply;
		filter: contrast(1) brightness(0.96);
		pointer-events: none;
		z-index: -2;
		transform: translateZ(0);
	}

	.hero {
		position: relative;
		z-index: 1;
		min-height: 100svh;
		min-height: 100dvh;
		display: grid;
		place-items: center;
		padding:
			calc(var(--safe-top) + 1rem)
			calc(var(--safe-right) + 1rem)
			calc(var(--safe-bottom) + 1rem)
			calc(var(--safe-left) + 1rem);
	}

	.hero::before {
		content: "";
		position: fixed;
		inset: 0;
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.44), transparent 52%),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.3));
		pointer-events: none;
		z-index: -1;
		transform: translateZ(0);
	}

	.content {
		width: min(920px, 100%);
		max-width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: clamp(0.8rem, 1.5vh, 1.05rem);
		padding: clamp(1rem, 2vw, 2rem) 0;
	}

	.eyebrow {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--soft-ink);
	}

	h1 {
		margin: 0;
		max-width: 12ch;
		font-size: clamp(2.6rem, 7vw, 6.6rem);
		line-height: 0.98;
		font-weight: 500;
		letter-spacing: -0.055em;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.08em;
		text-wrap: balance;
	}

	.headline-rotator {
		position: relative;
		display: inline-flex;
		align-items: flex-start;
		justify-content: center;
		min-width: 11ch;
		height: 1.18em;
		overflow: hidden;
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(0, 0, 0, 0.18) 5%,
			#000 18%,
			#000 82%,
			rgba(0, 0, 0, 0.18) 95%,
			transparent 100%
		);
		mask-image: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(0, 0, 0, 0.18) 5%,
			#000 18%,
			#000 82%,
			rgba(0, 0, 0, 0.18) 95%,
			transparent 100%
		);
	}

	.headline-track {
		display: flex;
		flex-direction: column;
		align-items: center;
		will-change: transform;
		animation: headline-cycle 4.8s cubic-bezier(0.72, 0, 0.28, 1) infinite;
	}

	.headline-word {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 1.18em;
		padding-bottom: 0.08em;
	}

	.headline-static {
		display: block;
		color: rgba(20, 20, 20, 0.84);
	}

	.meta {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-size: clamp(0.92rem, 1.35vw, 1.12rem);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--soft-ink);
	}

	.cta {
		margin-top: 0.2rem;
		padding: 0.95rem 1.7rem;
		border: 1px solid var(--line);
		background: var(--panel);
		font-family: Arial, Helvetica, sans-serif;
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.email {
		margin-top: clamp(0.85rem, 3vh, 2.2rem);
		width: min(100%, 42rem);
		font-size: clamp(1rem, 2vw, 1.18rem);
		letter-spacing: 0.02em;
	}

	.email-shell {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0.78rem 1rem;
		border: 1px solid rgba(20, 20, 20, 0.16);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.3);
		box-shadow:
			0 10px 30px rgba(20, 20, 20, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.55);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		font-family: "SFMono-Regular", "SF Mono", Consolas, "Liberation Mono", Menlo, monospace;
	}

	.email-text {
		position: relative;
		display: inline-block;
		max-width: 100%;
		color: rgba(20, 20, 20, 0.9);
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	.email-text::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -0.14rem;
		height: 1px;
		background: linear-gradient(
			90deg,
			rgba(20, 20, 20, 0),
			rgba(20, 20, 20, 0.42),
			rgba(20, 20, 20, 0)
		);
		transform-origin: center;
		animation: email-glow 3.4s ease-in-out infinite;
	}

	.socials {
		display: flex;
		gap: 1rem;
		align-items: center;
		justify-content: center;
	}

	.socials a {
		width: 3.2rem;
		height: 3.2rem;
		display: grid;
		place-items: center;
		border: 1px solid rgba(20, 20, 20, 0.24);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.24);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.socials svg {
		width: 1.55rem;
		height: 1.55rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.7;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.socials .fill {
		fill: currentColor;
		stroke: none;
	}

	@media (max-width: 720px) {
		.hero {
			padding:
				calc(var(--safe-top) + 0.85rem)
				calc(var(--safe-right) + 0.9rem)
				calc(var(--safe-bottom) + 0.9rem)
				calc(var(--safe-left) + 0.9rem);
		}

		.content {
			gap: 0.85rem;
		}

		h1 {
			max-width: 9.4ch;
			font-size: clamp(2.25rem, 11vw, 4.15rem);
		}

		.headline-rotator {
			min-width: 8.7ch;
		}

		.meta {
			font-size: 0.82rem;
			letter-spacing: 0.12em;
		}

		.cta {
			padding: 0.85rem 1.35rem;
			font-size: 0.82rem;
		}

		.email {
			font-size: 0.96rem;
		}

		.email-shell {
			padding: 0.72rem 0.9rem;
		}

		.socials a {
			width: 3rem;
			height: 3rem;
		}
	}

	@media (max-width: 430px) {
		h1 {
			max-width: 8.8ch;
			font-size: clamp(2.05rem, 10.8vw, 3.35rem);
		}

		.headline-rotator {
			min-width: 8.05ch;
		}

		.meta {
			font-size: 0.76rem;
			letter-spacing: 0.1em;
		}

		.email {
			font-size: 0.92rem;
		}
	}

	@media (max-height: 760px) {
		.hero {
			padding-top: calc(var(--safe-top) + 0.7rem);
			padding-bottom: calc(var(--safe-bottom) + 0.7rem);
		}

		.content {
			gap: 0.72rem;
		}

		h1 {
			font-size: clamp(2.15rem, 8.2vh, 4.6rem);
		}

		.email {
			margin-top: 0.8rem;
		}
	}

	@keyframes headline-cycle {
		0% {
			transform: translateY(0);
		}
		33.333% {
			transform: translateY(-1.18em);
		}
		66.666% {
			transform: translateY(-2.36em);
		}
		100% {
			transform: translateY(-3.54em);
		}
	}

	@keyframes email-glow {
		0%,
		100% {
			opacity: 0.35;
			transform: scaleX(0.82);
		}
		50% {
			opacity: 0.8;
			transform: scaleX(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.headline-rotator {
			min-width: auto;
			height: auto;
			overflow: visible;
			-webkit-mask-image: none;
			mask-image: none;
		}

		.headline-track {
			animation: none;
		}

		.headline-word {
			display: none;
		}

		.headline-word:first-child {
			display: flex;
		}

		.email-text::after {
			animation: none;
		}
	}
</style>