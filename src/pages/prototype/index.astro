---
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
import { editions, featuredEdition } from '../../data/site';

const textures = [
	'6.webp',
	'10.webp',
	'12.webp',
	'14.webp',
	'18.webp',
	'20.webp',
	'23.webp',
	'27.webp',
	'29.webp',
	'30.webp',
];

const shapes = ['shape-featured', 'shape-square', 'shape-medium', 'shape-tall', 'shape-soft'];

const cardPool = editions.flatMap((edition, index) => {
	const textureOffset = index * 3;
	const titleShape = shapes[index % shapes.length];
	const detailShape = shapes[(index + 4) % shapes.length];

	return [
		{
			href: `/prototype/editions/${edition.slug}`,
			kicker: edition.state,
			meta: `${edition.year} / ${edition.duration}`,
			metaParts: [edition.year, edition.duration],
			title: edition.title,
			copy: edition.strapline,
			texture: textures[textureOffset % textures.length],
			start: edition.palette.start,
			end: edition.palette.end,
			accent: edition.palette.accent,
			shape: titleShape,
			kind: index === 0 ? 'brand' : 'title',
			showMark: false,
		},
		{
			href: `/prototype/editions/${edition.slug}`,
			kicker: edition.path,
			meta: 'Edition notes',
			metaChip: true,
			title: edition.theme,
			copy: edition.unlock,
			texture: textures[(textureOffset + 1) % textures.length],
			start: edition.palette.start,
			end: '#1b1511',
			accent: edition.palette.accent,
			shape: detailShape,
			kind: 'detail',
			showMark: false,
		},
	];
});

const initialCards = cardPool.slice(0, 9);
---

<Layout
	title="Regal State Editions"
	description="A minimal card-led homepage for moving through the Regal State archive."
	bodyClass="home-page"
>
	<Header currentPath="/prototype" />

	<main class="minimal-home">
		<section class="home-intro" aria-labelledby="home-title">
			<p class="home-note">Scroll forever. Open what catches.</p>
			<h1 class="sr-only" id="home-title">Regal State Editions home</h1>
		</section>

		<section class="card-feed" id="card-feed" aria-label="Homepage cards" data-card-feed data-cursor={initialCards.length}>
			{
				initialCards.map((card, index) => (
					<a
						class={`home-card ${card.shape} ${card.kind === 'quote' ? 'is-quote' : ''} ${card.kind === 'brand' ? 'is-brand' : ''} ${card.kind === 'detail' ? 'is-detail' : ''}`}
						href={card.href}
						id={index === 0 ? 'featured-card' : undefined}
						style={`--card-start: ${card.start}; --card-end: ${card.end}; --card-accent: ${card.accent}; --texture-image: url('/textures-lowres/${card.texture}');`}
					>
						<div class="card-shell">
							<div class="card-meta">
								<span>{card.kicker}</span>
								{
									card.metaParts ? (
										<span class="card-meta-pills">
											{card.metaParts.map((part) => <span class="card-pill">{part}</span>)}
										</span>
									) : card.metaChip ? (
										<span class="card-meta-pills">
											<span class="card-pill card-pill-accent">{card.meta}</span>
										</span>
									) : (
										<span>{card.meta}</span>
									)
								}
							</div>

							<div class="card-body">
								{card.showMark && <img class="card-mark" src="/LOGO_1.svg" alt="" />}
								<h2>{card.title}</h2>
								<p>{card.copy}</p>
							</div>
						</div>
					</a>
				))
			}
		</section>

		<div class="scroll-anchor" id="scroll-anchor" data-feed-sentinel aria-hidden="true">
			<span>More cards loading as you scroll</span>
		</div>
	</main>

	<script id="home-card-data" type="application/json" set:html={JSON.stringify(cardPool)}></script>
	<script is:inline>
		const initInfiniteCards = () => {
			const feed = document.querySelector('[data-card-feed]');
			const sentinel = document.querySelector('[data-feed-sentinel]');
			const dataScript = document.getElementById('home-card-data');

			if (!feed || !sentinel || !dataScript || feed.dataset.ready === 'true') {
				return;
			}

			const pool = JSON.parse(dataScript.textContent || '[]');

			if (!Array.isArray(pool) || pool.length === 0) {
				return;
			}

			feed.dataset.ready = 'true';

			const createCard = (card) => {
				const link = document.createElement('a');
				link.href = card.href;
				link.className = `home-card ${card.shape} ${card.kind === 'quote' ? 'is-quote' : ''} ${card.kind === 'brand' ? 'is-brand' : ''} ${card.kind === 'detail' ? 'is-detail' : ''}`;
				link.style.setProperty('--card-start', card.start);
				link.style.setProperty('--card-end', card.end);
				link.style.setProperty('--card-accent', card.accent);
				link.style.setProperty('--texture-image', `url('/textures-lowres/${card.texture}')`);

				link.innerHTML = `
					<div class="card-shell">
						<div class="card-meta">
							<span>${card.kicker}</span>
							${
								Array.isArray(card.metaParts)
									? `<span class="card-meta-pills">${card.metaParts.map((part) => `<span class="card-pill">${part}</span>`).join('')}</span>`
									: card.metaChip
										? `<span class="card-meta-pills"><span class="card-pill card-pill-accent">${card.meta}</span></span>`
									: `<span>${card.meta}</span>`
							}
						</div>
						<div class="card-body">
							${card.showMark ? '<img class="card-mark" src="/LOGO_1.svg" alt="" />' : ''}
							<h2>${card.title}</h2>
							<p>${card.copy}</p>
						</div>
					</div>
				`;

				return link;
			};

			let cursor = Number(feed.dataset.cursor || feed.children.length);
			let appending = false;

			const appendBatch = (size = 6) => {
				if (appending) {
					return;
				}

				appending = true;

				for (let step = 0; step < size; step += 1) {
					const card = pool[cursor % pool.length];
					feed.appendChild(createCard(card));
					cursor += 1;
				}

				feed.dataset.cursor = String(cursor);
				appending = false;
			};

			const observer = new IntersectionObserver(
				(entries) => {
					if (entries.some((entry) => entry.isIntersecting)) {
						appendBatch(6);
					}
				},
				{ rootMargin: '900px 0px' },
			);

			observer.observe(sentinel);
		};

		document.addEventListener('astro:page-load', initInfiniteCards);
		initInfiniteCards();
	</script>
</Layout>

<style is:global>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	:global(body.home-page) {
		--text: #201914;
		--muted: rgba(32, 25, 20, 0.72);
		--soft: rgba(32, 25, 20, 0.52);
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.88), transparent 30%),
			linear-gradient(180deg, #f7f1e7 0%, #efe3d1 52%, #eadcc8 100%);
		color: var(--text);
	}

	:global(body.home-page .site-backdrop) {
		background:
			radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.58), transparent 25%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.22), transparent 180px);
		mask-image: none;
		opacity: 0.7;
	}

	.minimal-home {
		position: relative;
		z-index: 1;
		width: min(760px, calc(100% - 36px));
		margin: 0 auto;
		padding: 22px 0 88px;
		mask-image: linear-gradient(to bottom, transparent 0, rgba(0, 0, 0, 0.9) 84px, rgba(0, 0, 0, 0.9) 100%);
	}

	.home-intro {
		padding-bottom: 18px;
	}

	.home-note {
		margin: 0;
		font-family: 'IBM Plex Mono', 'Cascadia Code', monospace;
		font-size: 0.74rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--soft);
	}

	.card-feed {
		columns: 2 280px;
		column-gap: 24px;
	}

	.home-card {
		position: relative;
		display: block;
		width: 100%;
		margin: 0 0 24px;
		overflow: hidden;
		break-inside: avoid;
		text-decoration: none;
		color: #f8f0e7;
		box-shadow:
			0 18px 38px rgba(80, 57, 31, 0.12),
			inset 0 1px 0 rgba(255, 255, 255, 0.14);
		transition:
			transform var(--dur-mid) var(--ease-snappy),
			box-shadow var(--dur-mid) ease;
	}

	.home-card::before,
	.home-card::after {
		content: '';
		position: absolute;
		inset: 0;
	}

	.home-card::before {
		background:
			radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--card-accent) 38%, transparent), transparent 42%),
			linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(12, 9, 7, 0.28)),
			linear-gradient(145deg, color-mix(in srgb, var(--card-start) 90%, black 10%), color-mix(in srgb, var(--card-end) 82%, black 18%));
	}

	.home-card::after {
		background:
			linear-gradient(160deg, rgba(255, 255, 255, 0.08), rgba(14, 10, 8, 0.12)),
			var(--texture-image) center/cover;
		mix-blend-mode: overlay;
		opacity: 0.96;
		filter: saturate(1.18) contrast(1.08);
	}

	.home-card:hover {
		transform: translateY(-6px);
		box-shadow:
			0 22px 42px rgba(80, 57, 31, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.16);
	}

	.home-card.is-brand::before {
		background:
			radial-gradient(circle at 22% 22%, color-mix(in srgb, var(--card-accent) 44%, transparent), transparent 40%),
			linear-gradient(155deg, rgba(255, 255, 255, 0.18), rgba(12, 9, 7, 0.2)),
			linear-gradient(150deg, color-mix(in srgb, var(--card-start) 88%, black 12%), color-mix(in srgb, var(--card-end) 78%, black 22%));
	}

	.home-card.is-detail {
		color: #f8f0e7;
		box-shadow:
			0 18px 38px rgba(80, 57, 31, 0.14),
			inset 0 1px 0 rgba(255, 255, 255, 0.12);
	}

	.home-card.is-detail::before {
		background:
			linear-gradient(180deg, rgba(255, 248, 238, 0.07), rgba(255, 248, 238, 0)),
			radial-gradient(circle at 84% 16%, color-mix(in srgb, var(--card-accent) 22%, transparent), transparent 20%),
			linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(12, 9, 7, 0.24)),
			linear-gradient(145deg, color-mix(in srgb, var(--card-start) 84%, white 5%), color-mix(in srgb, var(--card-end) 70%, #2b2119 30%));
	}

	.home-card.is-detail::after {
		inset: 0;
		width: auto;
		height: auto;
		border-radius: inherit;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(14, 10, 8, 0.16)),
			repeating-linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.045) 0,
				rgba(255, 255, 255, 0.045) 1px,
				transparent 1px,
				transparent 30px
			),
			var(--texture-image) center/cover;
		mix-blend-mode: soft-light;
		opacity: 0.88;
		filter: saturate(0.9) contrast(1.02);
	}

	.home-card.is-detail:hover {
		box-shadow:
			0 22px 42px rgba(80, 57, 31, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.14);
	}

	.card-shell {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: inherit;
		height: 100%;
		padding: clamp(1.15rem, 3vw, 1.6rem);
	}

	.card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		font-family: 'IBM Plex Mono', 'Cascadia Code', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		color: rgba(248, 240, 231, 0.74);
	}

	.card-meta span:last-child:not(.card-meta-pills) {
		text-align: right;
	}

	.home-card.is-detail .card-meta {
		color: rgba(248, 240, 231, 0.68);
	}

	.card-meta-pills {
		display: inline-flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 6px;
		max-width: 100%;
	}

	.card-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 24px;
		padding: 0 10px;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--card-accent) 46%, white 10%);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-accent) 30%, white 6%), color-mix(in srgb, var(--card-accent) 72%, black 18%));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
		color: #fff8f1;
		white-space: nowrap;
	}

	.card-pill-accent {
		padding: 6px 10px 5px;
		border: 1px solid color-mix(in srgb, var(--card-accent) 82%, black 12%);
		border-radius: 6px;
		background: var(--card-accent);
		box-shadow:
			2px 2px 0 color-mix(in srgb, var(--card-accent) 35%, black 65%),
			0 0 0 1px rgba(255,255,255,0.06) inset;
		font-size: 0.61rem;
		line-height: 1;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		font-weight: 800;
		color: #fff;
	}

	.home-card.is-detail .card-pill-accent {
		position: relative;
		padding: 6px 12px 5px 24px;
		border-color: color-mix(in srgb, var(--card-accent) 58%, white 8%);
		border-radius: 999px;
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-accent) 22%, white 10%), color-mix(in srgb, var(--card-accent) 62%, black 10%));
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.24),
			0 0 0 1px rgba(255, 255, 255, 0.05);
		font-size: 0.59rem;
		letter-spacing: 0.16em;
		color: #fff8f1;
	}

	.home-card.is-detail .card-pill-accent::before {
		content: '';
		position: absolute;
		left: 10px;
		top: 50%;
		width: 8px;
		height: 8px;
		border-radius: 2px;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.88), color-mix(in srgb, var(--card-accent) 82%, black 6%));
		transform: translateY(-50%) rotate(45deg);
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12);
	}

	.card-body {
		display: grid;
		gap: 10px;
		align-content: end;
	}

	.card-mark {
		width: 84px;
		height: auto;
		opacity: 0.9;
	}

	.card-body h2 {
		margin: 0;
		max-width: 10ch;
		font-size: clamp(2rem, 4.2vw, 3rem);
		line-height: 0.94;
		letter-spacing: -0.07em;
	}

	.card-body p {
		margin: 0;
		max-width: 22ch;
		font-size: 0.98rem;
		line-height: 1.45;
		color: rgba(248, 240, 231, 0.78);
	}

	.home-card.is-detail .card-body {
		gap: 10px;
		padding-top: 6px;
	}

	.home-card.is-detail .card-body h2 {
		max-width: 10.5ch;
		font-size: clamp(1.9rem, 4vw, 2.7rem);
		line-height: 0.95;
		color: #f8f0e7;
	}

	.home-card.is-detail .card-body p {
		max-width: 23ch;
		color: rgba(248, 240, 231, 0.74);
	}

	.shape-featured {
		min-height: 320px;
		border-radius: 38px 38px 46px 42px;
	}

	.shape-square {
		min-height: 240px;
		border-radius: 34px;
	}

	.shape-tall {
		min-height: 430px;
		border-radius: 34px 34px 46px 46px;
	}

	.shape-medium {
		min-height: 300px;
		border-radius: 36px 36px 42px 40px;
	}

	.shape-soft {
		min-height: 270px;
		border-radius: 34px 42px 36px 44px;
	}

	.scroll-anchor {
		display: flex;
		justify-content: center;
		padding: 10px 0 0;
	}

	.scroll-anchor span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 34px;
		padding: 0 16px;
		border-radius: 999px;
		border: 1px solid rgba(38, 26, 19, 0.12);
		background: rgba(255, 255, 255, 0.48);
		font-family: 'IBM Plex Mono', 'Cascadia Code', monospace;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--soft);
	}

	@media (max-width: 720px) {
		.minimal-home {
			width: min(100% - 26px, 760px);
			padding-top: 18px;
			padding-bottom: 72px;
			mask-image: linear-gradient(to bottom, transparent 0, rgba(0, 0, 0, 0.9) 72px, rgba(0, 0, 0, 0.9) 100%);
		}

		.card-feed {
			column-count: 2;
			column-width: auto;
			column-gap: 16px;
		}

		.home-card {
			margin-bottom: 16px;
		}

		.card-meta {
			align-items: flex-start;
			flex-direction: column;
			gap: 6px;
			font-size: 0.58rem;
			letter-spacing: 0.08em;
		}

		.card-meta-pills {
			justify-content: flex-start;
			gap: 4px;
			width: 100%;
		}

		.card-pill {
			min-height: 20px;
			padding: 0 8px;
			max-width: 100%;
		}

		.card-pill-accent {
			padding: 5px 8px 4px;
			font-size: 0.54rem;
			letter-spacing: 0.14em;
			white-space: normal;
		}

		.card-body {
			gap: 8px;
		}

		.card-body h2 {
			max-width: none;
			font-size: clamp(1.3rem, 5vw, 1.75rem);
			line-height: 0.98;
			letter-spacing: -0.05em;
		}

		.card-body p {
			max-width: none;
			font-size: 0.82rem;
			line-height: 1.32;
		}

		.home-card.is-detail .card-body {
			padding-top: 4px;
		}
	}

	@media (max-width: 340px) {
		.card-feed {
			column-count: 1;
			column-width: auto;
			column-gap: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-card,
		.nav-link {
			transition: none;
		}
	}
</style>
