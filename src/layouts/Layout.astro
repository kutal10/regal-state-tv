---
interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
}

const {
	title = 'Regal State Editions',
	description = 'A premium long-form-first prototype for collectible video editions.',
	bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<div class="site-backdrop" aria-hidden="true"></div>
		<slot />
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600;700&display=swap');

	:root {
		--bg: #0a0d10;
		--bg-elevated: rgba(17, 21, 26, 0.9);
		--surface: rgba(255, 255, 255, 0.035);
		--surface-strong: rgba(255, 255, 255, 0.065);
		--hairline: rgba(255, 255, 255, 0.085);
		--hairline-strong: rgba(255, 255, 255, 0.14);
		--text: #f2efe8;
		--muted: rgba(242, 239, 232, 0.72);
		--soft: rgba(242, 239, 232, 0.5);
		--accent: #c6b598;
		--accent-soft: rgba(198, 181, 152, 0.16);
		--container: min(1120px, calc(100% - 48px));
		--radius: 28px;
		--radius-small: 18px;
		--shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
		--dur-fast: 180ms;
		--dur-mid: 320ms;
		--dur-slow: 620ms;
		--ease-snappy: cubic-bezier(0.22, 1, 0.36, 1);
		--ease-soft: cubic-bezier(0.2, 0.9, 0.3, 1);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		color-scheme: dark;
		background: var(--bg);
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: 'Instrument Sans', 'Avenir Next', 'Segoe UI', sans-serif;
		background:
			radial-gradient(circle at top, rgba(198, 181, 152, 0.09), transparent 26%),
			radial-gradient(circle at 84% 18%, rgba(255, 255, 255, 0.05), transparent 16%),
			linear-gradient(180deg, #0d1014 0%, #090c10 58%, #07090c 100%);
		color: var(--text);
		line-height: 1.6;
		text-rendering: optimizeLegibility;
	}

	::selection {
		background: rgba(198, 181, 152, 0.22);
		color: var(--text);
	}

	.site-backdrop {
		position: fixed;
		inset: 0;
		pointer-events: none;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0, transparent 180px),
			radial-gradient(circle at 18% 100%, rgba(198, 181, 152, 0.1), transparent 24%);
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 92%);
	}

	.site-backdrop::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			repeating-linear-gradient(
				90deg,
				rgba(255, 255, 255, 0.015) 0,
				rgba(255, 255, 255, 0.015) 1px,
				transparent 1px,
				transparent 112px
			),
			linear-gradient(180deg, transparent 0, rgba(255, 255, 255, 0.012) 100%);
		opacity: 0.32;
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}

	main {
		position: relative;
		z-index: 1;
	}

	.page-shell {
		width: var(--container);
		margin: 0 auto;
		padding: 24px 0 96px;
	}

	.section {
		margin-top: clamp(3.5rem, 8vw, 6rem);
		animation: section-enter var(--dur-slow) var(--ease-soft) both;
	}

	.section:first-child {
		margin-top: clamp(1.5rem, 4vw, 3rem);
	}

	.panel {
		position: relative;
		padding: clamp(1.2rem, 2.2vw, 1.8rem);
		border-radius: var(--radius);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.02)),
			var(--bg-elevated);
		border: 1px solid var(--hairline);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
	}

	.display-title {
		margin: 0;
		max-width: 10ch;
		font-size: clamp(3.3rem, 8vw, 6rem);
		line-height: 0.92;
		letter-spacing: -0.065em;
	}

	.eyebrow {
		margin: 0 0 14px;
		font-family: 'IBM Plex Mono', 'Cascadia Code', monospace;
		font-size: 0.73rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--soft);
	}

	.lead {
		margin: 20px 0 0;
		max-width: 42rem;
		font-size: clamp(1.05rem, 1.75vw, 1.22rem);
		color: var(--muted);
	}

	.hero-grid,
	.split-grid,
	.story-grid,
	.info-grid,
	.metric-grid {
		display: grid;
		align-items: start;
		gap: clamp(1.2rem, 2.2vw, 2rem);
	}

	.hero-grid {
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
	}

	.split-grid,
	.story-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.info-grid,
	.metric-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.card-grid {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: clamp(1rem, 1.8vw, 1.4rem);
	}

	.card-grid > * {
		grid-column: span 4;
	}

	.action-row,
	.chip-row,
	.small-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.action-row,
	.chip-row {
		margin-top: 22px;
	}

	.small-meta {
		font-family: 'IBM Plex Mono', 'Cascadia Code', monospace;
		font-size: 0.74rem;
		color: var(--soft);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.muted {
		color: var(--muted);
	}

	.soft {
		color: var(--soft);
	}

	.chip {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		width: fit-content;
		padding: 8px 12px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.07);
		background: rgba(255, 255, 255, 0.03);
		color: var(--muted);
		font-size: 0.8rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		padding: 12px 18px;
		border-radius: 999px;
		border: 1px solid transparent;
		background: #ece8df;
		color: #111317;
		font-weight: 600;
		letter-spacing: -0.02em;
		text-decoration: none;
		transition:
			transform var(--dur-fast) var(--ease-snappy),
			background-color var(--dur-fast) ease,
			border-color var(--dur-fast) ease;
	}

	.button:hover {
		transform: translateY(-1px);
		background: #f4f0e8;
	}

	.button:active {
		transform: translateY(1px) scale(0.992);
	}

	.button.secondary {
		background: rgba(255, 255, 255, 0.035);
		color: var(--text);
		border-color: rgba(255, 255, 255, 0.08);
	}

	.button.secondary:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.text-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--text);
		font-size: 0.94rem;
		text-decoration: none;
	}

	.text-link::after {
		content: '->';
		color: var(--soft);
		transition: transform var(--dur-fast) var(--ease-snappy);
	}

	.text-link:hover::after {
		transform: translateX(3px);
	}

	.metric {
		padding: 16px 0;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}

	.metric strong {
		display: block;
		font-size: 1.35rem;
		letter-spacing: -0.04em;
	}

	.metric span {
		display: block;
		margin-top: 8px;
		color: var(--muted);
		font-size: 0.95rem;
	}

	.progress-bar {
		height: 8px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		overflow: hidden;
	}

	.progress-fill {
		height: 100%;
		border-radius: inherit;
		background: linear-gradient(90deg, rgba(242, 239, 232, 0.88), rgba(198, 181, 152, 0.9));
	}

	.info-list,
	.progress-list,
	.timeline,
	.stack-list {
		display: grid;
		gap: 12px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.info-list li,
	.progress-list li,
	.timeline li,
	.list-link {
		padding: 16px;
		border-radius: var(--radius-small);
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
	}

	.progress-list li {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.progress-pill {
		font-size: 0.74rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--soft);
	}

	.list-link {
		display: block;
		text-decoration: none;
		transition:
			transform var(--dur-fast) var(--ease-snappy),
			background-color var(--dur-fast) ease,
			border-color var(--dur-fast) ease;
	}

	.list-link:hover {
		transform: translateY(-2px);
		background: rgba(255, 255, 255, 0.045);
		border-color: rgba(255, 255, 255, 0.11);
	}

	.quote-card blockquote {
		margin: 0;
		font-size: clamp(1.35rem, 2vw, 1.95rem);
		line-height: 1.2;
		letter-spacing: -0.04em;
	}

	.quote-card p {
		margin: 16px 0 0;
		color: var(--muted);
	}

	@keyframes section-enter {
		from {
			opacity: 0;
			transform: translateY(18px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 980px) {
		.hero-grid,
		.split-grid,
		.story-grid,
		.info-grid,
		.metric-grid {
			grid-template-columns: 1fr;
		}

		.card-grid > * {
			grid-column: span 6;
		}
	}

	@media (max-width: 720px) {
		:root {
			--container: min(100% - 32px, 1120px);
			--radius: 24px;
			--radius-small: 16px;
		}

		.page-shell {
			padding-bottom: 72px;
		}

		.card-grid > * {
			grid-column: 1 / -1;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}

		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
